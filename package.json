{
  "name": "goodfellow",
  "version": "2.0.0",
  "description": "Unified gazette processing pipeline for Brazilian official gazettes",
  "main": "src/index.ts",
  "type": "module",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "goodfellow:dev": "npx tsx dev/dev-setup.ts --cloudflare",
    "goodfellow:dev:localtunnel": "npx tsx dev/dev-setup.ts --localtunnel",
    "goodfellow:dev:localhost": "npx tsx dev/dev-setup.ts --localhost",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "type-check:strict": "tsc --noEmit --strict",
    "prepare": "husky install",
    "test": "npx tsx test-local.ts",
    "test:multiple": "npx tsx test-multiple-cities.ts",
    "test:automated": "npx tsx scripts/run-tests.ts",
    "test:automated:full": "npx tsx scripts/run-tests.ts full",
    "test:automated:sample": "npx tsx scripts/run-tests.ts sample",
    "test:automated:until": "npx tsx scripts/run-tests.ts until",
    "test:city": "npx tsx scripts/test-city.ts",
    "test:platform": "npx tsx scripts/test-platform.ts",
    "find:city": "npx tsx scripts/find-city.ts",
    "setup:webhook": "npx tsx scripts/setup-concursos-webhook.ts",
    "test:database": "npx tsx scripts/setup-database.ts",
    "setup:secrets": "npx tsx scripts/setup-secrets.ts",
    "run:today-yesterday": "npx tsx scripts/run-today-yesterday.ts",
    "test:capitals": "npx tsx scripts/test-capitals.ts",
    "test:local": "npx tsx scripts/test-local-pipeline.ts",
    "remote:crawl": "npx tsx scripts/remote-crawl.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:studio:local": "bun --env-file=.dev.vars run drizzle-kit studio",
    "test:d1": "npx tsx scripts/test-d1-setup.ts",
    "test:d1:prod": "npx tsx scripts/test-d1-setup.ts --production",
    "setup:d1": "npx tsx scripts/setup-d1.ts",
    "import:ocr": "npx tsx dev/import-data.ts ocr",
    "import:gazette": "npx tsx dev/import-data.ts gazette",
    "import:all": "npx tsx dev/import-data.ts all"
  },
  "keywords": [
    "cloudflare-workers",
    "crawler",
    "gazette",
    "brazil",
    "open-data"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/puppeteer": "^1.0.4",
    "@hono/node-server": "^1.19.5",
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.6",
    "glob": "^11.0.3",
    "hono": "^4.9.9",
    "localtunnel": "^2.0.2",
    "node-html-parser": "^7.0.1",
    "playwright": "^1.55.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.1.1",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251003.0",
    "@types/cheerio": "^0.22.35",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^24.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.4.1",
    "drizzle-kit": "^0.31.5",
    "husky": "^9.1.7",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "wrangler": "^4.42.0"
  }
}
